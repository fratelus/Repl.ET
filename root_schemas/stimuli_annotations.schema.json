{
  "title": "Repl.ET Stimuli Annotations Schema",
  "type": "object",
  "required": [
    "annotations"
  ],
  "properties": {
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stimulus_id",
          "ground_truth"
        ],
        "properties": {
          "stimulus_id": {
            "type": "string"
          },
          "ground_truth": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "region": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "required": [
                "label"
              ],
              "anyOf": [
                {
                  "required": [
                    "line"
                  ]
                },
                {
                  "required": [
                    "region"
                  ]
                }
              ]
            }
          }
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": false
}